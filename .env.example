# SentryQ Security Analysis Platform - Environment Variables
# Copy this file to .env and adjust values as needed

# Ollama Configuration
OLLAMA_HOST=localhost:11434
SENTRYQ_DEFAULT_MODEL=qwen2.5-coder:7b

# Server Configuration
SENTRYQ_PORT=5336
SENTRYQ_BIND=127.0.0.1
# Set to 0.0.0.0 to allow LAN access (requires SENTRYQ_AUTH_TOKEN for security)

# Optional authentication token (recommended when SENTRYQ_BIND=0.0.0.0)
# SENTRYQ_AUTH_TOKEN=your-secret-token-here

# Scan timeout (default: 60 minutes)
SENTRYQ_SCAN_TIMEOUT_MINUTES=60

# NVD API Key (optional - for higher rate limits in threat intelligence)
NVD_API_KEY=

# AI Provider API Keys (optional — can also be configured in the web UI)
# SENTRYQ_CLAUDE_API_KEY=
# SENTRYQ_GEMINI_API_KEY=
# SENTRYQ_CUSTOM_API_KEY=

# Frontend Configuration (for build time)
VITE_APP_VERSION=2.0.0
