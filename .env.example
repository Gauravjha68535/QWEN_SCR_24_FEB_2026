# SentryQ Security Analysis Platform - Environment Variables
# Copy this file to .env and adjust values as needed

# Ollama Configuration
OLLAMA_HOST=localhost:11434
SENTRYQ_DEFAULT_MODEL=qwen2.5-coder:7b

# Scanner Configuration
SENTRYQ_MAX_FILE_SIZE=256000

# Server Configuration
SENTRYQ_PORT=5336
SENTRYQ_DB_PATH=sentryq.db

# NVD API Key (optional - for higher rate limits in threat intelligence)
NVD_API_KEY=

# Air-gap mode (skip remote rule downloads)
SENTRYQ_AIRGAP=false

# Frontend Configuration (for build time)
VITE_APP_VERSION=2.0.0
